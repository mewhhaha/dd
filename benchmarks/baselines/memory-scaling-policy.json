{
  "name": "memory-scaling-smoke",
  "allow_dirty_results": true,
  "assertions": [
    {
      "name": "cross-shard atomic readwrite advantage at 8 isolates",
      "metric": "throughput_rps",
      "operator": ">=ratio",
      "left": {
        "mode": "atomic-readwrite-memory-wide",
        "keys": "cross-shard",
        "isolates": 8,
        "shards": 8
      },
      "right": {
        "mode": "atomic-readwrite-memory-wide",
        "keys": "same-shard",
        "isolates": 8,
        "shards": 8
      },
      "value": 1.5,
      "min_samples": 3,
      "max_cv": 0.35
    },
    {
      "name": "cross-shard atomic readwrite scales from one isolate",
      "metric": "throughput_rps",
      "operator": ">=ratio",
      "left": {
        "mode": "atomic-readwrite-memory-wide",
        "keys": "cross-shard",
        "isolates": 8,
        "shards": 8
      },
      "right": {
        "mode": "atomic-readwrite-memory-wide",
        "keys": "cross-shard",
        "isolates": 1,
        "shards": 8
      },
      "value": 1.5,
      "min_logical_cpus": 4,
      "min_samples": 3,
      "max_cv": 0.35
    },
    {
      "name": "direct write cross-shard smoke floor",
      "metric": "throughput_rps",
      "operator": "baseline",
      "selector": {
        "mode": "direct-write-memory-wide",
        "keys": "cross-shard",
        "isolates": 8,
        "shards": 8
      },
      "baseline": 1000,
      "warning": 0.5,
      "failure": 0.75,
      "direction": "higher-is-better",
      "min_samples": 3,
      "max_cv": 0.35
    }
  ]
}
